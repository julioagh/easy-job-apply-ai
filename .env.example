# Configuración de Easy Job Apply AI
# Copiar este archivo a .env y ajustar los valores según tu entorno

# Rutas del proyecto (usar rutas absolutas o relativas)
PROJECT_ROOT=/Users/tu_usuario/Apps/gihub-repos/easy-job-apply-ai
OUTPUTS_DIR=outputs
SESSIONS_DIR=sessions
TEMPLATES_DIR=templates
RESUMES_DIR=resumes_txt

# Configuración de CVs
DEFAULT_CV_LANGUAGE=auto  # auto, es, en
MAX_CV_PAGES=2
DEFAULT_FONT=Arial
DEFAULT_FONT_SIZE=9

# Formato de nombre de archivo CV
# "FirstLast" = CV_JulioGonzales_Company_Position.docx
# "Last" = CV_Gonzales_Company_Position.docx
CV_FILENAME_FORMAT=FirstLast

# Configuración de análisis
SALARY_ANALYSIS_DETAILED=true
DEFAULT_CURRENCY=USD
DEFAULT_LOCATION=Remoto LATAM

# Configuración de LLM (para automatización futura)
# LLM_PROVIDER=anthropic  # anthropic, openai, google
# LLM_API_KEY=tu-api-key
# LLM_MODEL=claude-sonnet-4

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/easy-job-apply.log
