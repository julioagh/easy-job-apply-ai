# .gitignore

# Archivos de sesión (pueden contener información sensible)
sessions/*.yaml
sessions/*.md
sessions/fase*_input_*.txt
!sessions/README.md

# CVs generados (información personal)
outputs/*.docx
outputs/*.md
outputs/*.pages
outputs/*.pdf
outputs/*.txt
!outputs/README.md

# CVs personales (información sensible)
resumes_txt/*.txt
!resumes_txt/README.md

# CVs base/master (información personal)
resumes_base/
!resumes_base/README.md

# Templates personalizados (pueden ser privados)
templates/*.docx
!templates/README.md

# Archivos generados accidentalmente en raíz (deberían estar en sessions/ u outputs/)
/context_*.yaml
/analisis_*.md
/CV_*.md
/CV_*.docx
/CV_*.pdf
/CV_*.pages

# Archivos de sistema
.DS_Store
.vscode/
.idea/

# Archivos temporales
*.tmp
*.bak
~$*.docx

# Logs
*.log

# Python (si se automatiza)
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
.env

# Node (si se crea interfaz web)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
